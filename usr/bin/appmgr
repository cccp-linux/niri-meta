#!/bin/bash

readonly conf="${XDG_CONFIG_HOME:-${HOME}/.config}/appmgr.conf"
readonly norm=$(tput sgr0)

scan_app()
{
    local args c icon name row

    while IFS='|' read -r icon c name args; do
        c=$(tput setaf $c)
        printf "${c}%1s  ${norm}%-22s\t%s\n" "$icon" "$name" "$args"
    done < "$conf"
}

sleep .1
fzf=(fzf --ansi
    --delimiter=$'\t'
    --margin=0,$(( (`tput cols` - 25 - 3) / 2 ))
    --no-info
    --prompt="app:"
    --reverse
    --with-nth=1 --accept-nth=2
)

choice=$(scan_app | "${fzf[@]}")
[[ "$choice" ]] && setsid $choice >/dev/null 2>&1 & sleep .2
