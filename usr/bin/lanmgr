#!/bin/bash

scan_net()
{
    readonly cyan=$(tput setaf 6)
    readonly norm=$(tput sgr0)
    readonly yell=$(tput setaf 3)

    local active conn eth name op

    while IFS=: read -r active name _ _; do
        [[ "$active" == "yes" ]] && active="➤" op="down" || active= op="up"
        eth="󰈀" conn="󱘖"
        printf "${norm}%1s ${yell}%1s  ${norm}%-32s  ${cyan}%1s\t%s\t%s\n" \
            "$active" "$eth" "$name" "$conn" "$name" "$op"
    done < <(nmcli -t -f active,name,device,type connection show | grep -E ":($dev|):802-3-ethernet$")
}

export dev=${1:-eth0}
export -f scan_net

while :; do
    fzf=(fzf --ansi
        --bind="ctrl-r:reload(bash -c scan_net)"
        --delimiter=$'\t'
        --margin=0,$(( (`tput cols` - 40 - 3) / 2 ))
        --no-info
        --prompt="$dev:"
        --reverse
        --with-nth=1 --accept-nth=2,3
    )

    choice=$(scan_net | "${fzf[@]}")
    [[ "$choice" ]] || break

    name=$(echo "$choice" | cut -d $'\t' -f1)
    op=$(echo "$choice" | cut -d $'\t' -f2)

    echo "--"
    case "$op" in
        up) nmcli connection up "$name" ifname "$dev";;
        down) nmcli device disconnect "$dev";;
    esac && sleep 2 || read -p "Press ENTER to continue... "
done
