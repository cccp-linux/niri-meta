#!/bin/bash

if (($# < 1)); then
    echo "Usage: $(basename "$0") <action>"
    exit 1
fi

declare -A niri=(
    [ping]="echo pong"
    [quit]="niri msg action quit --skip-confirmation"
)

if typeset -p "$XDG_CURRENT_DESKTOP" 2>/dev/null | grep -q "declare -A"; then
    declare -n desktop="$XDG_CURRENT_DESKTOP"
    [[ -v desktop["$1"] ]] && ${desktop[$1]}
fi
