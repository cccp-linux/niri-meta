#!/bin/bash

scan_media()
{
    readonly cyan=$(tput setaf 6)
    readonly dim=$(tput dim)
    readonly green=$(tput setaf 2)
    readonly norm=$(tput sgr0)
    readonly red=$(tput setaf 1)
    readonly yell=$(tput sgr0 setaf 3)

    local -A child
    local -a fstype label mount path size w

    local n row val

    while read -r row; do
        eval "$row"
        case "$TYPE" in
            part|crypt)
                LABEL=${LABEL//\\x20/ } MOUNTPOINT=${MOUNTPOINT//\\x20/ }
                path+=("$NAME") size+=("$SIZE") fstype+=("$FSTYPE") label+=("$LABEL") mount+=("$MOUNTPOINT")

                val=("$NAME" "$SIZE" "$FSTYPE" "$LABEL" "$MOUNTPOINT")
                for n in "${!val[@]}"; do
                    (( ${#val[n]} > w[n] )) && w[$n]=${#val[$n]}
                done

                [[ "$PKNAME" ]] && child[$PKNAME]="$PATH"
            ;;
        esac
    done < <(lsblk -Ppo NAME,SIZE,TYPE,FSTYPE,LABEL,MOUNTPOINT,PKNAME)

    printf "%-${w[0]}s  %-${w[1]}s  %-${w[2]}s  %-${w[3]}s  %-${w[4]}s\n" \
        "PATH" "SIZE" "TYPE" "LABEL" "STATUS"

    local c f m p

    for n in "${!path[@]}"; do
        c= f="${fstype[$n]}" m="${mount[$n]}" p="${path[$n]}"

        if [[ "$f" == "crypto_LUKS" ]]; then
            [[ "${child[$p]}" ]] && c="${green}" m="󰍀" op="lock" || c="${red}" m="󰍁" op="unlock"
        else
            [[ "$m" ]] && c="${norm}" op="unmount" || c="${norm}${dim}" m="-" op="mount"
        fi

        printf "${norm}%-${w[0]}s  ${cyan}%-${w[1]}s  ${dim}%-${w[2]}s  ${yell}%-${w[3]}s  ${c}%-${w[4]}s\t%s\t%s\n" \
            "$p" "${size[$n]}" "$f" "${label[$n]}" "$m" "$p" "$op"
    done
}
export -f scan_media

while :; do
    fzf=(fzf --ansi
        --bind="ctrl-r:reload(bash -c scan_media)"
        --delimiter=$'\t'
        --header-lines=1
        --no-info
        --prompt="blk:"
        --reverse
        --with-nth=1 --accept-nth=2,3
    )

    choice=$(scan_media | "${fzf[@]}")
    [[ "$choice" ]] || break

    path=$(echo "$choice" | cut -d $'\t' -f1)
    op=$(echo "$choice" | cut -d $'\t' -f2)

    echo "--"
    udisksctl "$op" --block-device "$path" && sleep 2 || read -p "Press ENTER to continue... "
done
