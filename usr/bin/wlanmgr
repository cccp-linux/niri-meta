#!/bin/bash

scan_wifi()
{
    readonly cyan=$(tput sgr0 setaf 6)
    readonly dim=$(tput dim)
    readonly green=$(tput setaf 2)
    readonly norm=$(tput sgr0)
    readonly red=$(tput setaf 1)
    readonly yell=$(tput setaf 3)

    readonly color=("$red" "$yell" "$yell" "$green" "$green")
    readonly icon=(ůį§Į ůį§ü ůį§Ę ůį§• ůį§®)

    local -a active chan sec signal ssid
    local -A index

    while read -r row; do
        IFS=: read -r ac ch sc sg ss <<< "$row"
        [[ "$ss" ]] || continue

        id=${index[$ss]}
        if [[ ! "$id" ]]; then
            index[$ss]=${#active[@]}
            active+=("$ac") chan+=("$ch") sec+=("$sc") signal+=("$sg") ssid+=("$ss")
        else
            [[ "$ac" != "yes" ]] || active[$id]="$ac"
        fi
    done < <(nmcli -t -f active,chan,security,signal,ssid dev wifi list ifname "$dev")

    for n in "${!ssid[@]}"; do
        ss=${ssid[$n]}

        [[ "${active[$n]}" == "yes" ]] && ac="‚ě§" op="down" || ac="" op="up"

        id=$((signal[n] * (${#icon[@]} - 1) / 100))
        ic="${icon[$id]}" c="${color[$id]}"

        [[ "${sec[$n]}" == "--" ]] && sc="" || sc="ůįćĀ"

        (( chan[n] <= 13 )) && ch="" || ch="ůįéĪ"

        printf "${norm}%1s ${c}%1s  ${norm}%-32s ${dim}%1s ${cyan}%1s\t%s\t%s\n" \
            "$ac" "$ic" "$ss" "$ch" "$sc" "$ss" "$op"
    done
}

export dev=${1:-wlan0}
export -f scan_wifi

while :; do
    fzf=(fzf --ansi
        --bind="ctrl-r:reload(bash -c scan_wifi)"
        --bind="load:change-header()"
        --delimiter=$'\t'
        --header="Scanning..."
        --margin=0,$(( (`tput cols` - 41 - 3) / 2 ))
        --no-info
        --prompt="$dev:"
        --reverse
        --with-nth=1 --accept-nth=2,3
    )

    choice=$(scan_wifi | "${fzf[@]}")
    [[ "$choice" ]] || break

    ssid=$(echo "$choice" | cut -d $'\t' -f1)
    op=$(echo "$choice" | cut -d $'\t' -f2)

    echo "--"
    case "$op" in
        up) nmcli device wifi connect "$ssid" ifname "$dev" --ask;;
        down) nmcli device disconnect "$dev";;
    esac && sleep 2 || read -p "Press ENTER to continue... "
done
